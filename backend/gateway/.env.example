# Copy to backend/gateway/.env (gitignored) and fill in real values.
# NEVER commit .env. Production deploy reads these from Cloud Run / VPS secrets.

GATEWAY_ENV=development
GATEWAY_LISTEN_ADDR=:8090

# Supabase (anon key is public-safe in Unity; service role + JWT secret are server-only)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWT_SECRET=replace_me_with_supabase_jwt_secret
SUPABASE_SERVICE_ROLE_KEY=replace_me_with_supabase_service_role_key

# LLM provider keys - phase 1 needs Convai, phase 2 needs Anthropic + OpenAI.
# At least one must be set in production or readiness check fails.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
CONVAI_API_KEY=

# Redis for session, rate limit, transient cache
REDIS_URL=redis://localhost:6379/0

# Per-player LLM budgets - adjust based on observed cost during slice
LLM_RATE_LIMIT_PER_PLAYER_PER_MIN=30
LLM_TOKEN_BUDGET_PER_PLAYER_DAY=50000
