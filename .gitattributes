# Auto detect text files
* text=auto

# Unity source files - text, force LF line endings
*.cs text diff=csharp eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.compute text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.uss text eol=lf
*.uxml text eol=lf

# Unity YAML scene/prefab/asset (Force Text serialization)
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.playable text eol=lf
*.mask text eol=lf
*.brush text eol=lf
*.flare text eol=lf
*.fontsettings text eol=lf
*.guiskin text eol=lf
*.giparams text eol=lf
*.giant text eol=lf
*.ht text eol=lf
*.mixer text eol=lf
*.preset text eol=lf
*.terrainlayer text eol=lf

# Project settings (Unity project lives under unity/ subfolder; glob also catches future nested Unity projects)
**/ProjectSettings/* text eol=lf
**/Packages/manifest.json text eol=lf
**/Packages/packages-lock.json text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Config
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Shell scripts
*.ps1 text eol=crlf
*.sh text eol=lf

# 3D Models (LFS)
*.fbx filter=lfs diff=lfs merge=lfs -text
